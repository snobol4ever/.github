index 22dba7e5..82ded281 100644
--- a/src/runtime/unification.c
+++ b/src/runtime/unification.c
@@ -205,6 +205,17 @@ void rt_e_reset(int off)
     pl_env_reset(&g_pl_env_area, off);
 }
 /*--------------------------------------------------------------------------------------------------------------------*/
+/* PL-AREAS-3b — bounded-call frame entry: bump one callee frame off the E-area (same 8+16*nslots size as rt_enter) and
+ * return it. NO caller slot, NO if(!*slot) cache: a bounded call has its resume β elided (PL-BB-1), so the frame is never
+ * re-read and the cache (which only ever skipped the GC_malloc cost) is dead weight — and keeping it would dangle a stale
+ * pointer once the E-area is reset (the documented #1 corruption trap). The caller saves rt_e_mark before this bump and
+ * rt_e_resets after the bounded callee returns, reclaiming this frame (and everything it transitively bumped) in O(1). */
+void *rt_e_enter(int nslots)
+{
+    extern pl_area_t g_pl_env_area;
+    return pl_env_bump(&g_pl_env_area, 8 + 16 * (nslots > 0 ? nslots : 1));
+}
